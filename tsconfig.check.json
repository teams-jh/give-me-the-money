{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "esnext",
    "allowImportingTsExtensions": true,
    "plugins": [],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.check.tsbuildinfo"
  },
  "include": [
    "src/library/shared/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
